# Google Calendar — secret iCal feed (Settings → calendar → Integrate calendar → Secret address in iCal format)
GOOGLE_CALENDAR_ICAL_URL=https://calendar.google.com/calendar/ical/YOUR_EMAIL%40gmail.com/private-XXXXXXXX/basic.ics

# Alternatywa dla Nitro runtime config (opcjonalnie zamiast powyższego):
# NITRO_GOOGLE_CALENDAR_ICAL_URL=https://calendar.google.com/calendar/ical/.../basic.ics
