# --- Google OAuth (logowanie + auto-kalendarze) ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URI: https://TWOJA-DOMENA/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Losowy sekret: openssl rand -base64 32
AUTH_SECRET=
# Lokalnie: http://localhost:3000  |  Vercel: https://twoja-app.vercel.app
APP_URL=http://localhost:3000

# --- Persystencja tokenów (Vercel: dodaj Redis/KV z marketplace) ---
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Opcjonalny fallback iCal (bez OAuth) ---
GOOGLE_CALENDAR_ICAL_URL=

# Stas — tylko gdy nie używasz OAuth:
# STAS_CAL_ZAJECIA_ICAL_URL=
# STAS_CAL_WYDARZENIA_ICAL_URL=
# STAS_CAL_ZNAJOMI_ICAL_URL=
